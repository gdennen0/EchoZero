{
  "name": "Lane B Core Flow",
  "seed": 7,
  "steps": [
    {
      "label": "Add song from generated audio",
      "action": "add_song_from_path",
      "params": {
        "title": "Lane B Song",
        "audio_path": "__RUN_TEMP__/fixtures/import.wav"
      }
    },
    {
      "label": "Extract stems from imported song",
      "action": "extract_stems",
      "params": {
        "layer_id": "source_audio"
      }
    },
    {
      "label": "Extract drum events from drums stem",
      "action": "extract_drum_events",
      "params": {
        "layer_title": "Drums"
      }
    },
    {
      "label": "Classify drum events with generated model",
      "action": "classify_drum_events",
      "params": {
        "layer_title": "Drums",
        "model_path": "__RUN_TEMP__/fixtures/drum-model.pth"
      }
    },
    {
      "label": "Select first classified event",
      "action": "select_first_event",
      "params": {
        "layer_title": "Drum_Classified_Events"
      }
    },
    {
      "label": "Nudge selection right",
      "action": "nudge",
      "params": {
        "direction": "right",
        "steps": 1
      }
    },
    {
      "label": "Duplicate selection",
      "action": "duplicate",
      "params": {
        "steps": 1
      }
    },
    {
      "label": "Open push surface",
      "action": "open_push_surface",
      "params": {
        "layer_title": "Drum_Classified_Events"
      }
    },
    {
      "label": "Enable sync",
      "action": "enable_sync"
    },
    {
      "label": "Disable sync",
      "action": "disable_sync"
    },
    {
      "label": "Open pull surface",
      "action": "open_pull_surface",
      "params": {
        "layer_title": "Drum_Classified_Events"
      }
    },
    {
      "label": "Capture screenshot",
      "action": "screenshot",
      "params": {
        "filename": "lane-b-final.png"
      }
    }
  ]
}
