{
  "name": "Lane B Core Flow",
  "seed": 7,
  "steps": [
    {
      "label": "Add song from generated audio",
      "action": "song.add",
      "params": {
        "title": "Lane B Song",
        "audio_path": "__RUN_TEMP__/fixtures/import.wav"
      }
    },
    {
      "label": "Extract stems from imported song",
      "action": "timeline.extract_stems",
      "params": {
        "layer_id": "source_audio"
      }
    },
    {
      "label": "Capture post-stems checkpoint",
      "action": "capture.screenshot",
      "params": {
        "filename": "lane-b-post-stems.png"
      }
    },
    {
      "label": "Extract onsets from drums stem",
      "action": "timeline.extract_drum_events",
      "params": {
        "layer_title": "Drums"
      }
    },
    {
      "label": "Capture post-drum-events checkpoint",
      "action": "capture.screenshot",
      "params": {
        "filename": "lane-b-post-drum-events.png"
      }
    },
    {
      "label": "Extract classified drums from drums stem",
      "action": "timeline.extract_classified_drums",
      "params": {
        "layer_title": "Drums"
      }
    },
    {
      "label": "Capture post-classification checkpoint",
      "action": "capture.screenshot",
      "params": {
        "filename": "lane-b-post-classification.png"
      }
    },
    {
      "label": "Select first classified event",
      "action": "selection.first_event",
      "params": {
        "layer_title": "Kick"
      }
    },
    {
      "label": "Nudge selection right",
      "action": "timeline.nudge_selection",
      "params": {
        "direction": "right",
        "steps": 1
      }
    },
    {
      "label": "Duplicate selection",
      "action": "timeline.duplicate_selection",
      "params": {
        "steps": 1
      }
    },
    {
      "label": "Open push surface",
      "action": "transfer.workspace_open",
      "params": {
        "layer_title": "Kick",
        "direction": "push"
      }
    },
    {
      "label": "Apply push transfer plan",
      "action": "transfer.plan_apply"
    },
    {
      "label": "Capture post-push-apply checkpoint",
      "action": "capture.screenshot",
      "params": {
        "filename": "lane-b-post-push-apply.png"
      }
    },
    {
      "label": "Enable sync",
      "action": "sync.enable"
    },
    {
      "label": "Disable sync",
      "action": "sync.disable"
    },
    {
      "label": "Open pull surface",
      "action": "transfer.workspace_open",
      "params": {
        "layer_title": "Kick",
        "direction": "pull"
      }
    },
    {
      "label": "Apply pull transfer plan",
      "action": "transfer.plan_apply"
    },
    {
      "label": "Capture screenshot",
      "action": "capture.screenshot",
      "params": {
        "filename": "lane-b-final.png"
      }
    }
  ]
}
