{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "foundry.compatibility_report.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "artifactId",
    "consumer",
    "ok",
    "errors",
    "warnings",
    "error_details",
    "warning_details",
    "checkedAt"
  ],
  "properties": {
    "schema": { "const": "foundry.compatibility_report.v1" },
    "artifactId": { "type": "string" },
    "consumer": { "type": "string" },
    "ok": { "type": "boolean" },
    "errors": { "type": "array", "items": { "type": "string" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "error_details": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "path": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["error"] }
        }
      }
    },
    "warning_details": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "path", "message", "severity"],
        "properties": {
          "code": { "type": "string" },
          "path": { "type": "string" },
          "message": { "type": "string" },
          "severity": { "type": "string", "enum": ["warning"] }
        }
      }
    },
    "checkedAt": { "type": "string" }
  }
}
