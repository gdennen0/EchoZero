{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "foundry.train_run_spec.v1",
  "type": "object",
  "required": ["schema", "classificationMode", "data", "training"],
  "properties": {
    "schema": { "const": "foundry.train_run_spec.v1" },
    "classificationMode": { "enum": ["multiclass", "binary", "positive_vs_other"] },
    "model": {
      "type": "object",
      "properties": {
        "type": { "enum": ["baseline_sgd", "cnn", "crnn"] }
      }
    },
    "data": {
      "type": "object",
      "required": ["datasetVersionId", "sampleRate", "maxLength", "nFft", "hopLength", "nMels", "fmax"],
      "properties": {
        "datasetVersionId": { "type": "string" },
        "sampleRate": { "type": "integer", "minimum": 8000 },
        "maxLength": { "type": "integer", "minimum": 1 },
        "nFft": { "type": "integer", "minimum": 64 },
        "hopLength": { "type": "integer", "minimum": 1 },
        "nMels": { "type": "integer", "minimum": 8 },
        "fmax": { "type": "integer", "minimum": 1 }
      }
    },
    "training": {
      "type": "object",
      "required": ["epochs", "batchSize", "learningRate"],
      "properties": {
        "epochs": { "type": "integer", "minimum": 1 },
        "batchSize": { "type": "integer", "minimum": 1 },
        "learningRate": { "type": "number", "exclusiveMinimum": 0 },
        "seed": { "type": "integer" },
        "trainerProfile": { "enum": ["baseline_v1", "stronger_v1"] },
        "optimizer": { "enum": ["sgd_constant", "sgd_optimal"] },
        "regularizationAlpha": { "type": "number", "exclusiveMinimum": 0 },
        "averageWeights": { "type": "boolean" },
        "earlyStoppingPatience": { "type": "integer", "minimum": 1 },
        "minEpochs": { "type": "integer", "minimum": 1 },
        "classWeighting": { "enum": ["none", "balanced"] },
        "rebalanceStrategy": { "enum": ["none", "oversample"] },
        "augmentTrain": { "type": "boolean" },
        "augmentNoiseStd": { "type": "number", "minimum": 0 },
        "augmentGainJitter": { "type": "number", "minimum": 0 },
        "augmentCopies": { "type": "integer", "minimum": 0 },
        "syntheticMix": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "cap": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "promotion": {
      "type": "object",
      "properties": {
        "reference_run_id": { "type": "string" },
        "reference_artifact_id": { "type": "string" },
        "gate_policy": {
          "type": "object",
          "properties": {
            "macro_f1_floor": { "type": "number", "minimum": 0 },
            "max_regression_vs_reference": { "type": "number", "minimum": 0 },
            "max_real_vs_synth_gap": { "type": "number", "minimum": 0 },
            "per_class_recall_floors": {
              "type": "object",
              "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        }
      }
    }
  }
}
