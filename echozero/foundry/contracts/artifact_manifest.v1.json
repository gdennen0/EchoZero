{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "foundry.artifact_manifest.v1",
  "type": "object",
  "required": [
    "schema",
    "artifactId",
    "runId",
    "datasetVersionId",
    "specHash",
    "sharedContractFingerprint",
    "weightsPath",
    "classes",
    "classificationMode",
    "inferencePreprocessing",
    "taxonomy",
    "labelPolicy",
    "runtime"
  ],
  "properties": {
    "schema": { "const": "foundry.artifact_manifest.v1" },
    "artifactId": { "type": "string" },
    "runId": { "type": "string" },
    "datasetVersionId": { "type": "string" },
    "specHash": { "type": "string" },
    "sharedContractFingerprint": { "type": "string" },
    "artifactIdentity": {
      "type": "object",
      "required": [
        "artifactId",
        "runId",
        "datasetVersionId",
        "specHash",
        "sharedContractFingerprint"
      ],
      "properties": {
        "artifactId": { "type": "string" },
        "runId": { "type": "string" },
        "datasetVersionId": { "type": "string" },
        "specHash": { "type": "string" },
        "sharedContractFingerprint": { "type": "string" }
      }
    },
    "displayIdentity": {
      "type": "object",
      "properties": {
        "artifactId": { "type": "string" },
        "runId": { "type": "string" },
        "datasetVersionId": { "type": "string" },
        "weightsFile": { "type": "string" },
        "classes": { "type": "array", "items": { "type": "string" } },
        "classificationMode": { "type": "string" },
        "consumer": { "type": "string" }
      }
    },
    "weightsPath": { "type": "string" },
    "classes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "classificationMode": { "enum": ["multiclass", "binary", "positive_vs_other"] },
    "taxonomy": { "type": "object" },
    "labelPolicy": { "type": "object" },
    "syntheticProvenance": { "type": "object" },
    "promotionGate": { "type": "object" },
    "referenceComparison": { "type": "object" },
    "runtime": {
      "type": "object",
      "required": ["consumer", "backend", "device"]
    },
    "inferencePreprocessing": {
      "type": "object",
      "required": ["sampleRate", "maxLength", "nFft", "hopLength", "nMels", "fmax"]
    }
  }
}
